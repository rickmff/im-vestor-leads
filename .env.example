# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/profile
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/profile

# Prisma / Supabase — Postgres connection strings (Project Settings > Database)
DATABASE_URL=
DIRECT_URL=

# Supabase — JS client for Storage, Realtime, Data API (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Stripe — API keys (Developers > API keys)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Stripe — webhook signing secret (Developers > Webhooks > your endpoint)
STRIPE_WEBHOOK_SECRET=
# Stripe — Price IDs (one per product/price you create in the dashboard).
# Create each product in Stripe, then paste its Price ID (price_...) here.
STRIPE_PRICE_SUBSCRIPTION_MONTHLY=
STRIPE_PRICE_SUBSCRIPTION_ANNUAL=
STRIPE_PRICE_POKE_PACK_3=
STRIPE_PRICE_POKE_PACK_5=
STRIPE_PRICE_POKE_PACK_10=
# Poke packs as a monthly subscription (recurring price of the same product)
STRIPE_PRICE_POKE_PACK_3_MONTHLY=
STRIPE_PRICE_POKE_PACK_5_MONTHLY=
STRIPE_PRICE_POKE_PACK_10_MONTHLY=
STRIPE_PRICE_LEAD_CREDIT=
