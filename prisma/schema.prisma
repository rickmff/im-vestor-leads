generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "esm"
  runtime      = "nodejs"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ENTREPRENEUR
  INVESTOR
  ADMIN
}

enum NotificationType {
  MESSAGE_RECEIVED
}

enum Sector {
  TECHNOLOGY
  HEALTHCARE
  FINTECH
  EDTECH
  CLEANTECH
  ECOMMERCE
  SAAS
  AGRITECH
  PROPTECH
  BIOTECH
}

enum InvestmentRange {
  R_10K_50K   @map("10K-50K")
  R_50K_200K  @map("50K-200K")
  R_200K_500K @map("200K-500K")
  R_500K_1M   @map("500K-1M")
  R_1M_5M     @map("1M-5M")
  R_5M_PLUS   @map("5M+")
}

model User {
  id           String   @id @default(cuid())
  clerkId      String   @unique
  email        String   @unique
  name         String?
  country      String?
  role         UserRole @default(ENTREPRENEUR)
  referralCode String   @unique

  referredByCode String?
  referrer       User?   @relation("Referrals", fields: [referredByCode], references: [referralCode])
  referrals      User[]  @relation("Referrals")

  investmentCapacity InvestmentRange?
  sectors            Sector[]

  // Shop / Stripe
  pokes              Int     @default(1)
  leadCredits        Int     @default(0)
  subscriptionPlan   String? // "monthly" | "annual" | null
  subscriptionStatus String? // Stripe subscription status, when applicable
  stripeCustomerId   String? @unique

  lastSeenAt DateTime?

  sentMessages  Message[]      @relation("SentMessages")
  conversations Conversation[] @relation("ConversationParticipants")
  notifications Notification[] @relation("UserNotifications")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Conversation {
  id           String    @id @default(cuid())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  messages     Message[]
  participants User[]    @relation("ConversationParticipants")

  @@index([updatedAt])
  @@map("conversations")
}

model Message {
  id             String       @id @default(cuid())
  content        String
  createdAt      DateTime     @default(now())
  readAt         DateTime?
  senderId       String
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation("SentMessages", fields: [senderId], references: [id])

  @@index([conversationId, createdAt])
  @@index([conversationId, senderId, readAt])
  @@index([senderId])
  @@map("messages")
}

model Notification {
  id        String           @id @default(cuid())
  createdAt DateTime         @default(now())
  type      NotificationType
  read      Boolean          @default(false)
  userId    String
  senderId  String?
  message   String?
  user      User             @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, read])
  @@map("notifications")
}

model ProcessedStripeEvent {
  id        String   @id // Stripe event id (evt_...) — guards against duplicate delivery
  type      String
  createdAt DateTime @default(now())

  @@map("processed_stripe_events")
}

model BannedWord {
  id        String   @id @default(cuid())
  word      String   @unique
  createdAt DateTime @default(now())
  createdBy String

  @@index([word])
  @@map("banned_words")
}
